{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BrowserX",
  "version": "0.1.0",
  "identifier": "com.mintrouter.browserx",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BrowserX",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2RDVGOTY1RTIyMDNDMTAKUldRUVBDRGlaZm5WbGhNZ3BoMGE4eWxLTzRvaGt2dnllN1FOeUhVSE9MVEpEU0JpNGh1aHF2eXoK",
      "endpoints": [
        "https://github.com/MintRouter/BrowserX/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "msi", "nsis", "appimage", "deb"],
    "category": "Productivity",
    "copyright": "Copyright © 2026 MintRouter. All rights reserved.",
    "shortDescription": "Local antidetect browser profile manager",
    "longDescription": "BrowserX is a local, open-source desktop app for managing antidetect browser profiles: per-profile fingerprints, proxies, timezone/locale settings, and CDP-based automation.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
